# API server (see package.json dev:api)
PORT=3001

# ── In-app Klaviyo login (OAuth) ────────────────────────────────────────────
# 1) Klaviyo → https://www.klaviyo.com/manage-apps → create app, add redirect URI:
#    https://YOUR_VERCEL_HOST/api/auth/klaviyo/callback
#    (local: http://localhost:5173/api/auth/klaviyo/callback)
# 2) Scope: accounts:read (only scope this app requests).
# 3) Vercel → Settings → Environment Variables (Production + Preview as needed):
#    - AUTH_ENABLED=true
#    - AUTH_SESSION_SECRET=(32+ random chars)
#    - APP_BASE_URL=https://YOUR_VERCEL_HOST   (no trailing slash)
#    - KLAVIYO_OAUTH_CLIENT_ID / KLAVIYO_OAUTH_CLIENT_SECRET
#    - VITE_SKIP_AUTH_GATE=false  (or delete the var if you had set true)
# 4) Redeploy so Vite bakes VITE_* and the API picks up server vars.
# 5) Open /api/health on the deployed host; must return JSON before OAuth works.

# Client build — MUST be false/unset for in-app Klaviyo login. Set true only if
# you lock the site with Vercel Deployment Protection instead (no OAuth UI).
# https://vercel.com/docs/deployment-protection
VITE_SKIP_AUTH_GATE=false

# Site gate — Klaviyo OAuth (see checklist above). false = open API (local default).
AUTH_ENABLED=false
AUTH_SESSION_SECRET=
# Must match the URL users use in the browser (OAuth redirect_uri).
APP_BASE_URL=
KLAVIYO_OAUTH_CLIENT_ID=
KLAVIYO_OAUTH_CLIENT_SECRET=

# Recruiter Bearer token for POST/PUT /api/recruiter/*
RECRUITER_API_KEY=

# Greenhouse Harvest + webhooks
GREENHOUSE_API_KEY=
GREENHOUSE_WEBHOOK_SECRET=

# LumPages internal KB
LUMPAGES_BASE_URL=
LUMPAGES_API_KEY=

# Google Drive (optional; upload scaffold)
GOOGLE_APPLICATION_CREDENTIALS=
# Alternative: path to service account JSON key file
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_OFFER_FOLDER_ID=
