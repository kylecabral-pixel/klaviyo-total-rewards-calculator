# API server (see package.json dev:api)
PORT=3001

# ═══════════════════════════════════════════════════════════════════════════
# RECOMMENDED: Login via Vercel only (Deployment Protection)
# ═══════════════════════════════════════════════════════════════════════════
# 1) Vercel Dashboard → your project → Settings → Deployment Protection
#    https://vercel.com/docs/deployment-protection
#    Enable Password and/or Vercel Authentication for Production (and Preview if desired).
# 2) Vercel → Settings → Environment Variables (Production):
#      VITE_SKIP_AUTH_GATE=true
#      AUTH_ENABLED=false
#    (Remove KLAVIYO_* / AUTH_SESSION_SECRET / APP_BASE_URL if you added them for OAuth.)
# 3) Redeploy so the client rebuilds with VITE_SKIP_AUTH_GATE=true.
# 4) Visitors hit Vercel’s login first; the app does not show “Continue with Klaviyo”.

# Client — set true on Vercel when using Deployment Protection only (hides in-app OAuth UI).
# Local dev: keep false unless you are testing the skip path.
VITE_SKIP_AUTH_GATE=false

# Server — false when using Vercel-only login (no Klaviyo session on /api).
AUTH_ENABLED=false

# ── Optional: In-app Klaviyo OAuth (only if NOT using Vercel-only login above) ──
# Klaviyo → https://www.klaviyo.com/manage-apps — redirect:
#   https://YOUR_HOST/api/auth/klaviyo/callback
# Vercel env: AUTH_ENABLED=true, AUTH_SESSION_SECRET, APP_BASE_URL, KLAVIYO_OAUTH_*,
#             VITE_SKIP_AUTH_GATE=false, then redeploy.
AUTH_SESSION_SECRET=
APP_BASE_URL=
KLAVIYO_OAUTH_CLIENT_ID=
KLAVIYO_OAUTH_CLIENT_SECRET=

# Recruiter Bearer token for POST/PUT /api/recruiter/*
RECRUITER_API_KEY=

# Greenhouse Harvest + webhooks
GREENHOUSE_API_KEY=
GREENHOUSE_WEBHOOK_SECRET=

# LumPages internal KB
LUMPAGES_BASE_URL=
LUMPAGES_API_KEY=

# Google Drive (optional; upload scaffold)
GOOGLE_APPLICATION_CREDENTIALS=
# Alternative: path to service account JSON key file
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_OFFER_FOLDER_ID=
