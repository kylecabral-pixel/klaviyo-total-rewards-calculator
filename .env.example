# API server (see package.json dev:api)
PORT=3001

# Client build — skip Klaviyo login screen entirely (recommended with Vercel Deployment Protection).
# Dashboard: Project → Settings → Deployment Protection (password or SSO).
# https://vercel.com/docs/deployment-protection
# If true, also set AUTH_ENABLED=false on the server unless /api/* works; otherwise
# browser calls to /api/benefits, /api/offer, etc. will 401.
VITE_SKIP_AUTH_GATE=false

# Site gate — Klaviyo OAuth (create app + redirect URI at https://www.klaviyo.com/manage-apps)
# When false/unset, the app and APIs stay open (local dev default).
AUTH_ENABLED=false
AUTH_SESSION_SECRET=
# Public origin of the SPA (OAuth redirect). Local: http://localhost:5173  Vercel: https://your-project.vercel.app
APP_BASE_URL=
KLAVIYO_OAUTH_CLIENT_ID=
KLAVIYO_OAUTH_CLIENT_SECRET=

# Recruiter Bearer token for POST/PUT /api/recruiter/*
RECRUITER_API_KEY=

# Greenhouse Harvest + webhooks
GREENHOUSE_API_KEY=
GREENHOUSE_WEBHOOK_SECRET=

# LumPages internal KB
LUMPAGES_BASE_URL=
LUMPAGES_API_KEY=

# Google Drive (optional; upload scaffold)
GOOGLE_APPLICATION_CREDENTIALS=
# Alternative: path to service account JSON key file
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_OFFER_FOLDER_ID=
